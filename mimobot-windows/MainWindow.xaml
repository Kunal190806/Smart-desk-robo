<Window x:Class="MimobotControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mimobot Pro: Control Center" Height="700" Width="950" 
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        AllowDrop="True" Drop="Window_Drop">
    <Window.Resources>
        <!-- The Page Number Style -->
        <Style x:Key="PagePill" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PillBorder" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" Background="#EE0F0F0F" BorderBrush="#33FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/> <!-- New Right Sidebar -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="#1A1A1A" Grid.Column="0" Padding="20" CornerRadius="20,0,0,20">
                <StackPanel>
                    <TextBlock Text="MimoBot" Foreground="#00A3FF" FontSize="32" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Control Center" Foreground="White" FontSize="18" Margin="0,0,0,30"/>
                    <TextBlock Text="CONNECTION" Foreground="#555" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Background="#222" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="StatusLabel" Text="● Disconnected" Foreground="#FF4B4B" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <CheckBox x:Name="ToggleLabels" Content="Show App Names" Foreground="#888" IsChecked="True" Checked="ToggleLabels_Changed" Unchecked="ToggleLabels_Changed" Margin="0,0,0,20"/>
                    <Button Content="SYNC TO PI" Background="#00A3FF" Foreground="White" Padding="10" FontWeight="Bold" BorderThickness="0" Click="SyncAll_Click" Margin="0,0,0,10">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                    <Button Content="How to Setup?" Background="Transparent" Foreground="#555" FontSize="12" BorderThickness="0" Click="Help_Click" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Main Area -->
            <Grid Grid.Column="1" Margin="20">
                <Border x:Name="DynamicBackground" CornerRadius="20" Background="Transparent" Margin="-20"/>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                <TextBlock Text="STREAM DECK GRID" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <UniformGrid Rows="2" Columns="3" Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <!-- Slot 1 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot1" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="1">
                            <Grid>
                                <Image x:Name="Img1" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt1" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt1" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                    <!-- Slot 2 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot2" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="2">
                            <Grid>
                                <Image x:Name="Img2" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt2" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt2" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                    <!-- Slot 3 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot3" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="3">
                            <Grid>
                                <Image x:Name="Img3" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt3" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt3" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                    <!-- Slot 4 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot4" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="4">
                            <Grid>
                                <Image x:Name="Img4" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt4" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt4" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                    <!-- Slot 5 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot5" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="5">
                            <Grid>
                                <Image x:Name="Img5" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt5" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt5" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                    <!-- Slot 6 -->
                    <StackPanel Margin="15">
                        <Border x:Name="Slot6" Width="110" Height="110" BorderBrush="#333" BorderThickness="2" CornerRadius="22" Background="#080808" AllowDrop="True" Drop="Slot_Drop" MouseLeftButtonDown="Slot_Click" Tag="6">
                            <Grid>
                                <Image x:Name="Img6" Height="65" Width="65" Visibility="Collapsed" Stretch="Uniform"/>
                                <TextBlock x:Name="IconTxt6" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="Txt6" HorizontalAlignment="Center" Foreground="#666" Margin="0,10,0,0" FontSize="11"/>
                    </StackPanel>
                </UniformGrid>

                <!-- FINAL UNIFIED NAVIGATION PILL -->
                <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="20" Padding="10,5" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📌" Background="Transparent" Foreground="#555" BorderThickness="0" Margin="5,0" FontSize="12" Click="Pin_Click"/>
                        <ItemsControl x:Name="PagePills">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Button Content="+" Background="Transparent" Foreground="#00A3FF" FontSize="20" FontWeight="Bold" BorderThickness="0" Margin="10,0" Click="Page_Add_Click"/>
                    </StackPanel>
                </Border>
                </Grid>
            </Grid>

            <!-- Features Panel (Right Sidebar) -->
            <Border x:Name="FeaturesPanel" Grid.Column="2" Background="#111" Width="250" Padding="15" CornerRadius="0,20,20,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Content="⮜ Back" Background="Transparent" Foreground="#00A3FF" HorizontalAlignment="Left" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="BackToMain_Click" Margin="0,0,0,15"/>
                    <TextBlock x:Name="FeaturesTitle" Grid.Row="1" Text="App Features" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>
                    <ListBox x:Name="FeaturesList" Grid.Row="2" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="FeaturesList_MouseDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#222" CornerRadius="8" Padding="10" Margin="0,0,0,5" Width="200">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0" FontFamily="Segoe Fluent Icons"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#DDD" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- GLASSMORPHIC SETUP GUIDE -->
            <Border x:Name="HelpOverlay" Grid.ColumnSpan="3" Background="#EE000000" CornerRadius="20" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                    <TextBlock Text="Mimobot Pro Setup Guide" Foreground="#00A3FF" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="1. OBS WebSocket (V5)" Foreground="White" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="• Tools > WebSocket Server Settings" Foreground="#888" TextWrapping="Wrap"/>
                    <TextBlock Text="• Port: 4455 | No Auth (for local LAN)" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Text="2. Raspberry Pi Hub" Foreground="White" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="• Set Static IP: 192.168.1.100" Foreground="#888" TextWrapping="Wrap"/>
                    <TextBlock Text="• Port: 8000 (Open in Firewall)" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <Button Content="I'm Ready!" Background="#00A3FF" Foreground="White" Padding="20,10" FontWeight="Bold" BorderThickness="0" Margin="0,20,0,0" Click="Help_Close_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
